# Banco de dados (PostgreSQL - use Supabase, Neon ou outro)
# Supabase: https://supabase.com → Settings → Database → Connection String (URI)
# Neon: https://neon.tech → Dashboard → Connection string
DATABASE_URL="postgresql://user:password@host:5432/caravela"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-uma-chave-segura-com-openssl-rand-base64-32"

# Admin (login do painel)
ADMIN_EMAIL="admin@exemplo.com"
ADMIN_PASSWORD="sua-senha-aqui"

# WhatsApp do dono (só números, ex: 5511999999999)
NEXT_PUBLIC_WHATSAPP_NUMBER="5511999999999"

# Email (Resend - opcional, para notificar assinantes)
# Crie uma conta em https://resend.com e adicione sua chave
RESEND_API_KEY=""
EMAIL_FROM="Caravela Tabuleiria <noreply@seudominio.com>"
